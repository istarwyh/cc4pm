{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cc4pm Install Profiles",
  "description": "Named presets that bundle module IDs into ready-to-install groups.",
  "type": "object",
  "required": ["version", "profiles"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "number" },
    "profiles": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["description", "modules"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "modules": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          }
        }
      }
    }
  }
}
